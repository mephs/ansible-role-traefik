{{ ansible_managed | comment }}

services:
  traefik:
    image: {{ traefik_image_registry }}/{{ traefik_image_repository }}:{{ traefik_image_tag }}
    container_name: {{ traefik_container_name }}
    restart: unless-stopped
    security_opt: ["no-new-privileges:true"]
    networks: ["{{ traefik_docker_network }}"]
    ports:
      - {{ traefik_http_port }}:80
      - {{ traefik_https_port }}:443
{% if traefik_metrics_prometheus %}
      - {{ traefik_metrics_address }}:{{ traefik_metrics_port }}:8081
{% endif %}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./tls:/tls:ro
      - ./traefik.d:/traefik.d:ro
      - ./traefik.toml:/etc/traefik/traefik.toml:ro
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 5s
      timeout: 3s
      retries: 3
    labels:
      traefik.enable: true
{% if traefik_api_dashboard | bool %}
      traefik.http.routers.dashboard.rule: Host(`{{ traefik_dashboard_host }}`)
      traefik.http.routers.dashboard.service: api@internal
      traefik.http.routers.dashboard.entrypoints: {{ 'websecure' if traefik_dashboard_tls else 'web' }}
{% if traefik_dashboard_tls %}
      traefik.http.routers.dashboard.tls: true
{% endif %}
{% endif %}
{% if traefik_extra_labels %}
{{ traefik_extra_labels | to_nice_yaml(indent=2) | indent(6, True) }}
{% endif %}
networks:
  {{ traefik_docker_network }}:
    external: true
